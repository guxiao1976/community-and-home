# Model Configuration
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
MODEL_CACHE_DIR=/app/models
DEVICE=cuda
LOAD_IN_8BIT=true

# Server Configuration
HOST=0.0.0.0
PORT=8001
WORKERS=1
LOG_LEVEL=info

# Inference Configuration
MAX_LENGTH=512
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=50

# Performance
BATCH_SIZE=1
MAX_BATCH_WAIT_MS=50

# Cache (optional)
ENABLE_CACHE=false
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL_SECONDS=3600
